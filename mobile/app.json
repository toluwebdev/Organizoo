{
  "expo": {
    "name": "connectify",
    "slug": "connectify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/iosAppIconPng.png",
    "scheme": "connectify",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/logo/iosAppIconPng.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.connectify.connectify",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "icon": "./assets/logo/androidAppIcon.png",
      "adaptiveIcon": {
        "backgroundColor": "#100a30",
        "foregroundImage": "./assets/logo/androidAppIcon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.connectify.connectify"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/androidAppIcon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/androidAppIcon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#100a30",
          "dark": {
            "backgroundColor": "#100a30"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ${PRODUCT_NAME} to access your location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1371d41e-05a4-4f57-b8f6-9e124f527bb5"
      }
    }
  }
}
